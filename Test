pipeline {
    agent any

    triggers {
        cron('* * * * *')
    }

    environment {
        DATASTAGE_SERVER = 'tu-servidor-datastage'
        CSV_PATH         = "${WORKSPACE}/jobs_schedule.csv"
    }

    stages {

        stage('Capturar hora de inicio') {
            steps {
                script {
                    // ✅ Se captura UNA SOLA VEZ al arrancar el pipeline.
                    // Aunque los stages siguientes tarden, siempre se
                    // compara contra este valor fijo y no contra "ahora".
                    env.HORA_INICIO_CHILE = sh(
                        script: "TZ='America/Santiago' date '+%H:%M'",
                        returnStdout: true
                    ).trim()

                    echo "⏰ Hora de inicio del pipeline (Chile): ${env.HORA_INICIO_CHILE}"
                }
            }
        }

        stage('Leer CSV y filtrar jobs') {
            steps {
                script {
                    def horaInicio = env.HORA_INICIO_CHILE  // valor fijo, nunca cambia
                    def jobsParaEjecutar = []

                    def csvContent = readFile(env.CSV_PATH).trim()

                    csvContent.split('\n').drop(1).each { linea ->
                        linea = linea.trim()
                        if (!linea) return

                        def partes = linea.split(',')
                        if (partes.size() < 3) return

                        def nombreJob      = partes[0].trim()
                        def nombreProyecto = partes[1].trim()
                        def horasRaw       = partes[2].trim()

                        // ✅ Múltiples horas separadas por ";"
                        def horas = horasRaw.split(';').collect { it.trim() }

                        if (horas.contains(horaInicio)) {
                            jobsParaEjecutar << [
                                job:      nombreJob,
                                proyecto: nombreProyecto,
                                horas:    horasRaw
                            ]
                        }
                    }

                    if (jobsParaEjecutar.isEmpty()) {
                        echo "No hay jobs programados para las ${horaInicio}. Pipeline finaliza."
                        env.JOBS_JSON = '[]'
                        return
                    }

                    echo "Jobs a ejecutar a las ${horaInicio}:"
                    jobsParaEjecutar.each { j ->
                        echo "  → ${j.job} (${j.proyecto}) | Horarios: ${j.horas}"
                    }

                    env.JOBS_JSON = groovy.json.JsonOutput.toJson(jobsParaEjecutar)
                }
            }
        }

        stage('Ejecutar Jobs DataStage') {
            when {
                expression { env.JOBS_JSON && env.JOBS_JSON != '[]' }
            }
            steps {
                script {
                    def jobs = new groovy.json.JsonSlurper().parseText(env.JOBS_JSON)

                    def parallelStages = [:]

                    jobs.each { jobInfo ->
                        def jobNombre   = jobInfo.job
                        def jobProyecto = jobInfo.proyecto

                        parallelStages["${jobProyecto}/${jobNombre}"] = {
                            stage("Ejecutar ${jobNombre}") {
                                echo "▶ Iniciando: ${jobProyecto} / ${jobNombre}"

                                def exitCode = sh(
                                    script: """
                                        dsjob -server ${env.DATASTAGE_SERVER} \
                                              -run ${jobProyecto} ${jobNombre}
                                    """,
                                    returnStatus: true
                                )

                                if (exitCode == 0) {
                                    echo "✅ ${jobNombre} completado exitosamente"
                                } else {
                                    error "❌ ${jobNombre} falló con código de salida: ${exitCode}"
                                }
                            }
                        }
                    }

                    parallel parallelStages
                }
            }
        }
    }

    post {
        failure {
            echo "⚠️ Uno o más jobs DataStage fallaron a las ${env.HORA_INICIO_CHILE}."
        }
        success {
            echo "✅ Pipeline de las ${env.HORA_INICIO_CHILE} finalizado correctamente."
        }
    }
}
